# Environment Configuration
# Copy this file to .env and update with your values

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration (Required in Production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1h

# Database Configuration
# For local development, leave DATABASE_URL unset to use SQLite
# For production (Render), set DATABASE_URL to your PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: SQLite Database Path (only used when DATABASE_URL is not set)
# DB_STORAGE=./database/certapi.sqlite
